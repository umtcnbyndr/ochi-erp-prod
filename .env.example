# Database (Coolify: set via Coolify UI)
DATABASE_URL="postgresql://ochi:ochi_dev_password@localhost:5432/ochi_erp_v2?schema=public"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# App
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="Ochi ERP"
NEXT_PUBLIC_DEFAULT_PHARMACY_ID=1

# PSF sanity check threshold (alış < PSF × threshold → uyarı)
PSF_SANITY_THRESHOLD=0.1
