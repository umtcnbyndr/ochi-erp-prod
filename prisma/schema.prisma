/// Satın alma siparişi (distribütöre verilen)
model PurchaseOrder {
  id              Int      @id @default(autoincrement())
  /// Sipariş bir veya birden fazla markayı kapsayabilir
  brandIds        Int[]    @default([])
  status          PurchaseOrderStatus @default(DRAFT)

  /// Hesap parametreleri (snapshot)
  analysisDays    Int      @default(90)  // satış analizi için bakılan gün
  targetStockDays Int      @default(60)  // hedef stok günü

  /// Notlar
  note            String?

  /// Tutar özeti (cache — items'tan hesaplanır)
  totalListAmount Decimal  @default(0) @db.Decimal(14, 2)  // liste fiyat toplamı
  totalNetAmount  Decimal  @default(0) @db.Decimal(14, 2)  // net alış toplamı (KDV dahil)
  totalQuantity   Int      @default(0)

  /// Tarih
  createdAt       DateTime @default(now())
  confirmedAt     DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?

  /// Kullanıcı
  createdBy       String?

  items           PurchaseOrderItem[]

  @@index([status])
  @@index([createdAt])
}

/// Sipariş kalemi (her ürün için bir satır)
model PurchaseOrderItem {
  id              Int      @id @default(autoincrement())
  orderId         Int
  productId       Int

  /// Snapshot fiyatlar (sipariş anında dondurulur)
  listPrice       Decimal  @db.Decimal(14, 4)  // marka liste fiyatı
  isVatIncluded   Boolean  @default(false)
  netPurchasePrice Decimal @db.Decimal(14, 4)  // hesaplanmış net alış (KDV dahil, tüm iskontolar)

  /// Snapshot satış verileri
  currentStock    Int      // (LEGACY) sipariş anındaki ana+cadde stok toplam — geriye uyumluluk için tutuluyor
  mainStockSnapshot   Int?  // sipariş anındaki ana depo stoğu (yeni siparişlerde dolu, eski siparişlerde null)
  streetStockSnapshot Int?  // sipariş anındaki cadde stoğu
  totalSoldInPeriod   Int?  // analiz periyodunda toplam satılan adet (yeni alan, eski siparişlerde null)
  dailySalesAvg   Decimal  @default(0) @db.Decimal(10, 4)  // günlük ort. satış
  daysUntilStockout Int?   // tahmini bitme süresi (gün)

  /// Sipariş miktarları
  suggestedQty    Int      // sistem önerisi
  orderedQty      Int      // gerçek sipariş miktarı (kullanıcı override edebilir)
  receivedQty     Int      @default(0)  // mal kabul edilen toplam

  /// BuyBox bilgileri (snapshot)
  buyboxPrice     Decimal? @db.Decimal(14, 4)
  ourSalePrice    Decimal? @db.Decimal(14, 4)  // mevcut satış fiyatımız (recommendedPrice veya formula)

  order           PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])

  @@unique([orderId, productId])
  @@index([orderId])
  @@index([productId])
}

enum PurchaseOrderStatus {
  DRAFT       // taslak — düzenleniyor
  CONFIRMED   // onaylandı, satıcıya gitti
  PARTIAL     // kısmen geldi
  COMPLETED   // tamamı geldi
  CANCELLED   // iptal
}

// ---------- Kampanya (Marka iskonto kampanyaları) ----------
//
// İş mantığı:
//   - Marka der: "Mart boyunca %10 iskonto"
//   - İndirim TL = PSF × (oran/100)  (PSF üzerinden TL hesaplanır)
//   - Sanal alış = mainPurchasePrice - indirim_TL
//   - Dopigo'ya yansıyan satış = formul(sanal_alış, marketplace)
//   - Tahsilat = PSF_snapshot × oran% × satılan_adet (markaya fatura kesilir)
//
// Tip:
//   BRAND     — tüm markaya uygulanır
//   PRODUCTS  — manuel barkod listesi (CampaignProduct)
//
// Çakışma:
//   - PRODUCTS, BRAND'i ezer (more specific wins)
//   - Aynı ürün eş zamanlı 2 kampanyada olamaz (form kontrol)
model Campaign {
  id                  Int            @id @default(autoincrement())
  name                String         // "Skinceuticals Mart 2026"
  type                CampaignType
  brandId             Int?           // BRAND için (zorunlu)
  discountRate        Decimal        @db.Decimal(5, 2)  // 10.00 = %10
  startDate           DateTime
  endDate             DateTime
  status              CampaignStatus @default(ACTIVE)

  // Tahsilat
  collectionDueDate   DateTime?      // marka deadline (örn. ay sonu)
  collectedAt         DateTime?
  collectionInvoiceNo String?        // bizim kestiğimiz iskonto faturası
  collectedAmount     Decimal?       @db.Decimal(12, 2)

  notes               String?
  createdAt           DateTime       @default(now())
  endedAt             DateTime?      // status ENDED'a geçtiği an
  updatedAt           DateTime       @updatedAt

  brand    Brand?            @relation(fields: [brandId], references: [id])
  products CampaignProduct[] // PRODUCTS tipi için seçilen ürünler
  sales    CampaignSale[]
  payments CampaignPayment[]

  @@index([status])
  @@index([startDate, endDate])
  @@index([brandId])
}

/// Kampanya tahsilatı — parçalı ödeme kayıtları (50K → 30K şimdi + 20K sonra).
/// Tek seferlik kapama yerine kullanıcı her tahsilatı tarihiyle birlikte düşer.
/// Sum(amount) >= beklenen tutar OLDUĞUNDA otomatik COLLECTED, ama manuel
/// "tahsilat tamamlandı" butonu da var (eksik tahsilat kabul edilebilir).
model CampaignPayment {
  id          Int      @id @default(autoincrement())
  campaignId  Int
  amount      Decimal  @db.Decimal(12, 2)  // tahsil edilen tutar (TL)
  paymentDate DateTime                     // tahsilat tarihi (kullanıcı seçer)
  invoiceNo   String?                       // opsiyonel — kesilen iskonto fatura no
  notes       String?                       // opsiyonel — "havale", "kısmi" vs.
  createdAt   DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, paymentDate])
}

// PRODUCTS tipi kampanyaya dahil ürünler
model CampaignProduct {
  id         Int @id @default(autoincrement())
  campaignId Int
  productId  Int

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([campaignId, productId])
  @@index([productId])
}

// Kampanya boyunca yapılan satışlar — tahsilat hesabı için snapshot
model CampaignSale {
  id                   Int       @id @default(autoincrement())
  campaignId           Int
  productId            Int
  stockMovementId      Int?      // hangi OUT'tan geldi (audit)
  quantity             Int
  psfSnapshot          Decimal   @db.Decimal(12, 2)  // satış anındaki PSF
  unitPurchaseSnapshot Decimal   @db.Decimal(12, 2)  // satış anındaki alış
  discountAmountTL     Decimal   @db.Decimal(12, 2)  // (psf × oran% × adet) tahsilat tutarı
  saleDate             DateTime  // OUT tarihi
  source               String    // "STOCK_MOVEMENT" | "DOPIGO_ORDER" (ileride)
  createdAt            DateTime  @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@index([campaignId, saleDate])
  @@index([productId])
}

enum CampaignType {
  BRAND      // tüm marka
  PRODUCTS   // seçili ürünler
}

enum CampaignStatus {
  ACTIVE     // aktif (tarih aralığında, henüz bitmedi)
  ENDED      // bitti, henüz tahsil edilmedi
  COLLECTED  // tahsilat tamam
  CANCELLED  // iptal
}

// ---------- Audit Log (kritik islemler) ----------
//
// Hangi kullanici ne zaman ne yapti — kompleks islemlerin (kullanici yonetimi,
// trendyol config, kampanya tahsilati, login fail) izi.
//
// Bu tablo silinmemeli (audit). Cron ile eski kayitlari arsivlenip silinmesi
// admin tarafindan yapilabilir.
model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     String?  // null = system
  action     String   // "USER_CREATE", "TRENDYOL_CONFIG_UPDATE", "CAMPAIGN_END", "LOGIN_FAIL", vs.
  entityType String?  // "User", "Campaign", "Product", ...
  entityId   String?
  before     Json?    // değişiklik öncesi snapshot
  after      Json?    // değişiklik sonrası
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId])
}

// ---------- Komisyon Tarifeleri (Trendyol/HB/N11 haftalık tarife) ----------
//
// Trendyol Salı 08:00 - sonraki Salı 07:59 haftalık tarife yayınlar.
// Excel yüklenir, her ürün için 4 fiyat kademesi + komisyon oranı saklanır.
// Kullanıcı bir kademe seçer, sistem Excel export ile TY'ye geri yüklenecek
// dosyayı üretir.
//
// Critical: Sistemdeki TÜM komisyon hesabı (dopigo-sync, sale-price,
// recommendation, sales-analytics, coupon-*) artık bu tarifeden okur
// (lib/pricing/effective-commission.ts helper'ı üzerinden). Tarife yoksa
// fallback Marketplace.commissionRate kullanılır.

model CommissionTariffUpload {
  id            Int      @id @default(autoincrement())
  marketplace   String   // "Trendyol" | "Hepsiburada" | "N11" (Marketplace.name ile uyumlu)
  filename      String
  effectiveFrom DateTime // Tarifenin başlangıç tarihi (Salı 08:00)
  effectiveTo   DateTime // Tarifenin bitiş tarihi (sonraki Salı 07:59)
  rowCount      Int      @default(0)
  matchedCount  Int      @default(0) // ERP'ye eşleşen satır sayısı
  tarifeGrubu   String?  // Excel'deki "TARİFE GRUBU" alanı
  uploadedAt    DateTime @default(now())
  uploadedBy    String?  // userId

  tariffs CommissionTariff[]

  @@unique([marketplace, effectiveFrom])
  @@index([effectiveFrom, effectiveTo])
}

model CommissionTariff {
  id       Int @id @default(autoincrement())
  uploadId Int
  upload   CommissionTariffUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  // Dönem bilgisi (upload'dan kopya — query hızı için)
  marketplace   String
  effectiveFrom DateTime
  effectiveTo   DateTime

  // Trendyol ham verisi
  barcode              String
  modelKodu            String?
  satıcıStokKodu       String?  @map("satici_stok_kodu")
  productName          String
  brand                String?
  category             String?
  trendyolStock        Int?
  trendyolPrice        Decimal? @db.Decimal(12, 2) // GÜNCEL TSF
  currentCommissionPct Decimal? @db.Decimal(5, 2) // GÜNCEL KOMİSYON %
  baseCommissionPrice  Decimal? @db.Decimal(12, 2) // KOMİSYONA ESAS FİYAT
  isRecommended        Boolean  @default(false) // "Önerilen Ürün" rozeti

  // 4 kademe — alt limit (≥ bu fiyat) + komisyon %
  // tier1AltLimit ≥ → tier1CommissionPct
  // tier2AltLimit-tier2UstLimit → tier2CommissionPct
  // tier3AltLimit-tier3UstLimit → tier3CommissionPct
  // ≤ tier4UstLimit → tier4CommissionPct
  tier1AltLimit       Decimal? @db.Decimal(12, 2)
  tier1CommissionPct  Decimal? @db.Decimal(5, 2)
  tier2UstLimit       Decimal? @db.Decimal(12, 2)
  tier2AltLimit       Decimal? @db.Decimal(12, 2)
  tier2CommissionPct  Decimal? @db.Decimal(5, 2)
  tier3UstLimit       Decimal? @db.Decimal(12, 2)
  tier3AltLimit       Decimal? @db.Decimal(12, 2)
  tier3CommissionPct  Decimal? @db.Decimal(5, 2)
  tier4UstLimit       Decimal? @db.Decimal(12, 2)
  tier4CommissionPct  Decimal? @db.Decimal(5, 2)

  // ERP eşleştirmesi (TrendyolListing veya ProductBarcode üzerinden)
  productId Int?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  // Kullanıcının seçtiği kademe (Excel export'una yansır)
  selectedTier  Int?      // 1, 2, 3, 4
  selectedPrice Decimal?  @db.Decimal(12, 2) // Kademede önerilen yeni TSF
  applyToEnd    Boolean   @default(false) // "Tarife Sonuna Kadar Uygula" — default false
  selectedAt    DateTime?
  selectedBy    String?

  rawJson Json

  @@unique([uploadId, barcode])
  @@index([productId, marketplace])
  @@index([marketplace, effectiveFrom, effectiveTo])
}

// ===== Finans: Alış Faturaları =====
// Aracı eczaneden Ochi'ye gelen alış faturası + bizim karşı keseceğimiz iskonto faturası (alacak).
//
// Akış:
//  - Eczane bize fatura keser → grossAmount (bizim ödeyeceğimiz)
//  - Marka yıl sonu iskonto verir (örn %10) → discountAmount = gross × %/100 (bizim alacağımız)
//  - Alacak vadesi: discountDueDate (yıl sonu / quarter sonu / manuel tarih)
//  - Tahsilat parçalı: PurchaseInvoicePayment kayıtları = alacak tahsilatları
//  - discountStatus: tahsilat tamamlandı mı? (OPEN/PARTIAL/COLLECTED)
//
// brandId nullable → "Karışık" (yıl sonu iskonto kapsam dışı kayıtlar)
// Aynı (brand, period) için birden fazla fatura olabilir — ara kesimler yüzünden.

model PurchaseInvoice {
  id             Int      @id @default(autoincrement())
  /** Eczanenin fatura kesim tarihi */
  invoiceDate    DateTime
  /** YYYY-MM (örn "2026-01") — gruplama ve filtre için */
  period         String
  /** Eczane fatura no (opsiyonel) */
  invoiceNumber  String?
  /** Marka — null = "Karışık" (yıl sonu iskonto harici) */
  brandId        Int?
  /** Aracı eczane (Counterparty.type = PHARMACY) */
  counterpartyId Int
  /** Brüt tutar — eczane bize ne kestiyse (ödenecek) */
  grossAmount    Decimal  @db.Decimal(14, 2)
  /** İskonto yüzdesi (0-100). Marka × dönem bazında, manuel girilir. */
  discountPct    Decimal  @default(0) @db.Decimal(5, 2)
  /** İskonto tutarı (alacak) — application-side hesaplanır: gross × (%/100) */
  discountAmount Decimal  @db.Decimal(14, 2)
  /** İskonto alacağının vade tarihi (yıl sonu/quarter sonu/manuel). Null = vade yok. */
  discountDueDate DateTime?
  /** OPEN | PARTIAL | COLLECTED — tahsilat toplamına göre otomatik */
  discountStatus String   @default("OPEN")
  note           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  brand        Brand?       @relation(fields: [brandId], references: [id], onDelete: SetNull)
  counterparty Counterparty @relation(fields: [counterpartyId], references: [id])
  collections  PurchaseInvoicePayment[]

  @@index([period])
  @@index([brandId, period])
  @@index([counterpartyId])
  @@index([discountStatus])
  @@index([invoiceDate])
  @@index([discountDueDate])
}

/// İskonto alacağı tahsilatı (markadan/eczaneden geri alınan parçalı).
/// "PurchaseInvoicePayment" tabloyu rename etmeden devam — anlamı tahsilat olarak değişti.
model PurchaseInvoicePayment {
  id          Int      @id @default(autoincrement())
  invoiceId   Int
  /** Tahsilat tarihi */
  paymentDate DateTime
  /** Tahsil edilen tutar (alacaktan düşülür) */
  amount      Decimal  @db.Decimal(14, 2)
  /** Bizim karşı kestiğimiz fatura numarası (opsiyonel) */
  invoiceNumber String?
  /** Tahsilat notu (örn "havale", "kasa", "mahsup") */
  note        String?

  createdAt DateTime @default(now())
  createdBy String?

  invoice PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([paymentDate])
}

// ===== Finans: Gider Yönetimi =====
// Operasyonel giderler — kira, maaş, elektrik, ofis, koli vs.
// Pazaryeri brüt giderleri (komisyon/kargo/stopaj) Dopigo siparişlerden otomatik hesaplanır,
// bu tabloda DEĞİL.

enum ExpenseCategory {
  // Personel
  SALARY        // Maaş
  BONUS         // Prim
  MEAL          // Yemek
  INSURANCE     // Sigorta / SGK

  // İşyeri
  RENT          // Kira
  BUILDING_FEE  // Aidat
  ELECTRICITY   // Elektrik
  GAS           // Doğalgaz
  WATER         // Su
  INTERNET      // İnternet
  CLEANING      // Temizlik

  // Operasyonel paketleme
  BOX           // Koli
  NYLON         // Naylon
  LABEL         // Etiket
  TAPE          // Bant
  OFFICE        // Ofis malzemeleri

  // Yazılım/Servis
  SOFTWARE      // Yazılım abonelikleri (MS365, Excel, Mail, Shopify, vs)
  HOSTING       // Sunucu/Hosting
  DOMAIN        // Alan adı
  DOPIGO        // Dopigo aboneliği
  INTEGRATION   // Diğer entegrasyonlar
  SMS           // SMS gateway
  CREDIT        // Telefon kontör

  // Pazarlama
  ADVERTISING   // Reklam (Meta/Google Ads)
  CONTENT       // İçerik üretici / Influencer

  // Mali
  ACCOUNTING    // Muhasebe
  TAX           // Vergi (KDV/gelir)
  BANK_FEE      // Banka komisyon / havale

  OTHER         // Diğer (customCategory ile detay)
}

enum ExpensePeriodicity {
  ONE_TIME      // Tek seferlik
  MONTHLY       // Aylık tekrarlayan
  QUARTERLY     // Üç aylık
  YEARLY        // Yıllık
}

model Expense {
  id             Int                @id @default(autoincrement())
  /** Ödeme/gider tarihi */
  expenseDate    DateTime
  /** YYYY-MM — gruplama için */
  period         String
  category       ExpenseCategory
  /** Kategori OTHER ise serbest metin (ya da diğerleri için detay) */
  customCategory String?
  amount         Decimal            @db.Decimal(14, 2)
  /** Tekrarlama: tek seferlik mi sürekli mi (rapor amaçlı tag, otomatik kayıt değil) */
  periodicity    ExpensePeriodicity @default(ONE_TIME)
  /** Açıklama / kim için */
  description    String?
  /** Vendor (ödeme yapılan firma/kişi) */
  vendor         String?
  /** Personel ID — sadece SALARY/BONUS/MEAL/INSURANCE kategorilerinde anlamlı */
  employeeId     Int?
  employee       Employee?          @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  /** Fatura no opsiyonel */
  invoiceNumber  String?
  note           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@index([period])
  @@index([category])
  @@index([expenseDate])
  @@index([employeeId])
}

/// Personel kaydı — maaş/prim/yemek/sigorta giderleri için referans.
model Employee {
  id        Int       @id @default(autoincrement())
  name      String
  position  String?   // Pozisyon: depo, satış, muhasebe vs (opsiyonel)
  isActive  Boolean   @default(true)
  hiredAt   DateTime?
  leftAt    DateTime?
  note      String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  expenses  Expense[]

  @@index([isActive])
  @@index([name])
}

/// Aylık gelir/gider kaydı (snapshot).
/// İki kaynak:
///   - Manuel: kullanıcının elle girdiği geçmiş ay verileri (Oca-Nis 2026 vb)
///   - Otomatik: ay sonu Dopigo'dan hesaplanıp kaydedilen (May 2026+)
/// Snapshot varsa gelir/gider sayfası bunu kullanır, yoksa Dopigo'dan canlı hesaplar.
model MonthlySalesSnapshot {
  id          Int      @id @default(autoincrement())
  year        Int
  month       Int      // 1-12
  /** Bu ayın cirosu (satış toplamı) */
  revenue     Decimal  @db.Decimal(14, 2) @default(0)
  /** Alış maliyeti (ürün maliyeti toplamı) */
  cost        Decimal  @db.Decimal(14, 2) @default(0)
  /** Komisyon */
  commission  Decimal  @db.Decimal(14, 2) @default(0)
  /** Kargo */
  shipping    Decimal  @db.Decimal(14, 2) @default(0)
  /** Stopaj */
  withholding Decimal  @db.Decimal(14, 2) @default(0)
  /** Manuel mi otomatik (Dopigo'dan) mı kaydedildi */
  isManual    Boolean  @default(true)
  note        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@unique([year, month])
  @@index([year])
}

/// Satış prim baremleri — aylık NET ciroya (iade/iptal hariç) göre kademeli prim.
/// prim = aylık net ciro × ulaşılan kademe oranı. Ayarlar → Hedefler & Primler'den düzenlenir.
model SalesBonusTier {
  id        Int      @id @default(autoincrement())
  /// Bu ciroya ulaşınca bu kademe geçerli (TL)
  minSales  Decimal  @db.Decimal(14, 2)
  /// Prim oranı — çarpan (0.007 = %0.7). prim = ciro × bonusRate
  bonusRate Decimal  @db.Decimal(8, 6)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([minSales])
}

/// Prim sistemi genel ayarı (tek satır, id=1).
model SalesBonusConfig {
  id           Int      @id @default(1)
  /// Primi hak etmek için gereken min net kâr marjı (% — sadece gösterim, primi sıfırlamaz)
  minProfitPct Decimal  @db.Decimal(5, 2) @default(25)
  /// Ciro kaynağı: "ALL" (tüm pazaryerleri) | "TRENDYOL"
  salesBasis   String   @default("ALL")
  isActive     Boolean  @default(true)
  updatedAt    DateTime @updatedAt
}
