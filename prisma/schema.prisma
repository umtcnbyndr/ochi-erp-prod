// Ochi ERP — Prisma Schema
// Pharmacy ERP with marketplace-ready pricing engine

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth.js Tables ----------
model User {
  id            String    @id @default(cuid())
  username      String    @unique
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  role          UserRole  @default(STAFF)
  isActive      Boolean   @default(true)
  pharmacyId    Int       @default(1)
  /** "light" | "dark" | "system" — kullanıcı tercihli tema */
  themePreference String  @default("system")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  permissions   UserPermission[]
  panelNotes    PanelNote[]
  allowedBrands UserAllowedBrand[]

  @@index([pharmacyId])
  @@index([username])
}

/// Kullanıcının (özellikle SALES rolü) erişebileceği markaları kısıtlar.
/// Hiç kayıt yoksa → tüm markalara erişim (mevcut davranış korunur).
/// Kayıt varsa → sadece o markalarla ilgili siparişleri görür.
model UserAllowedBrand {
  id      Int    @id @default(autoincrement())
  userId  String
  brandId Int
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([userId, brandId])
  @@index([userId])
  @@index([brandId])
}

/// Panel sayfasındaki kişisel notlar / yapılacaklar.
/// Her kullanıcının kendi notları olur. Basit todo: text + done flag.
model PanelNote {
  id        Int      @id @default(autoincrement())
  userId    String
  text      String   @db.Text
  done      Boolean  @default(false)
  pinned    Boolean  @default(false) // önemli notları üste sabitle
  createdAt DateTime @default(now())
  doneAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, done])
  @@index([userId, pinned, createdAt])
}

// Kullanıcı bazlı modül izinleri
model UserPermission {
  id       Int     @id @default(autoincrement())
  userId   String
  module   String  // modül key'i (örn: "urunler", "markalar", "raporlar")
  canView  Boolean @default(false)
  canEdit  Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Core ERP Tables ----------
model Pharmacy {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Brand {
  id         Int      @id @default(autoincrement())
  pharmacyId Int      @default(1)
  name       String   @unique
  aliases    String[] @default([]) // Eski isimler / alternatif yazımlar — rename geçmişi, import'ta eşleme için

  // İskontolar (% — yüzde olarak tutulur, örn. 10 = %10)
  invoiceDiscount1 Decimal @default(0) @db.Decimal(5, 2)
  invoiceDiscount2 Decimal @default(0) @db.Decimal(5, 2)
  invoiceDiscount3 Decimal @default(0) @db.Decimal(5, 2)
  yearEndDiscount1 Decimal @default(0) @db.Decimal(5, 2)
  yearEndDiscount2 Decimal @default(0) @db.Decimal(5, 2)
  yearEndDiscount3 Decimal @default(0) @db.Decimal(5, 2)

  pharmacyMargin    Decimal @default(0) @db.Decimal(5, 2)
  pharmacyStockRule Int     @default(0)
  // Açılacak maksimum miktar — null = "üstünün TAMAMINI aç" (mevcut davranış)
  // Sayı = "kural üstünden EN ÇOK bu kadar aç" (örn 1 → sadece 1 aç).
  // Az hareketli ürünlerde gereksiz açma yapmamak için.
  pharmacyOpenAmount Int?

  // Pazaryeri hedef kar marjı (opsiyonel, % — örn. 30 = %30).
  // Doluysa marketplace.targetProfit'i override eder. Tüm pazar yerlerinde geçerli.
  // Boşsa marketplace'in kendi hedef karı kullanılır.
  targetProfit Decimal? @db.Decimal(5, 2)

  // BuyBox bazlı fiyat önerisinde rakibin ne kadar altına ineceğimiz (TL — sabit).
  // 0 = aynı fiyat, 5 = rakip fiyatı - 5 TL. priceUndercutBufferPct varsa o öncelikli.
  priceUndercutBuffer Decimal @default(0) @db.Decimal(10, 2)
  // BuyBox altına inerken yüzde tampon (orantılı). 5 = rakip fiyatı × 0.95.
  // Hem TL hem % varsa: % öncelikli (orantılı koruma daha güvenli).
  priceUndercutBufferPct Decimal @default(0) @db.Decimal(5, 2)

  distributorInfo String?
  contactInfo     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
  priceListItems BrandPriceList[]
  campaigns      Campaign[]
  marketplaceFloors BrandMarketplaceFloor[]
  purchaseInvoices PurchaseInvoice[]
  userAccess     UserAllowedBrand[]

  @@index([pharmacyId])
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  aliases   String[] @default([]) // Eski isimler — rename geçmişi, import'ta eşleme için
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subcategories Subcategory[]
  products      Product[]
}

model Subcategory {
  id         Int      @id @default(autoincrement())
  name       String
  aliases    String[] @default([]) // Eski isimler — rename geçmişi
  categoryId Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([name, categoryId])
  @@index([categoryId])
}

model Marketplace {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  commissionRate Decimal  @default(0) @db.Decimal(5, 2) // %
  shippingCost   Decimal  @default(0) @db.Decimal(10, 2) // TL sabit
  // Ek maliyet (TL sabit). Formülde kargo gibi paya eklenir.
  // Örn: ambalaj ücreti, return işlem ücreti, vs.
  extraCost      Decimal  @default(0) @db.Decimal(10, 2)
  withholdingTax Decimal  @default(0) @db.Decimal(5, 2) // stopaj %
  targetProfit   Decimal  @default(0) @db.Decimal(5, 2) // hedef kar %
  // Brand seviyesinde tampon yoksa kullanılır (TL — sabit)
  defaultUndercutBuffer Decimal? @db.Decimal(10, 2)
  // Brand seviyesinde tampon yoksa kullanılır (% — orantılı). % öncelikli.
  defaultUndercutBufferPct Decimal? @db.Decimal(5, 2)
  // BuyBox altına inerken min kar tabanı (%). Boşsa targetProfit kullanılır.
  // Örn: targetProfit=25 ama floor=10 → BuyBox bazlı öneri %10 kar tabanına kadar düşebilir.
  minProfitFloor Decimal? @db.Decimal(5, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  prices ProductMarketplacePrice[]
  brandFloors BrandMarketplaceFloor[]
  listings ProductMarketplaceListing[]
  dopigoOrders DopigoOrder[]
  monthlyExpenses MarketplaceMonthlyExpense[]
}

/**
 * Aynı ürünün bir marketplace'teki çoklu listing'leri.
 *
 * Senaryo: Mustela aynı 50ml kremi için TY'de 2 farklı barkodla listelemiş —
 * birinde 10 yorum (eski), birinde 500 yorum (yeni). Biz ERP'de tek ürün
 * tutuyoruz, ama Dopigo Excel export'ta her listing için ayrı satır gerekli.
 *
 * Stok ortak (Product.mainStock). Fiyat ortak (ProductMarketplacePrice).
 * Listing yalnız Dopigo Excel export'unda multi-row üretmek + BuyBox'ı
 * ayrı çekmek için kullanılır.
 *
 * isPrimary: birden fazla varsa default/anchor olarak kullanılır
 * (BuyBox sync, recommendation engine, vs).
 *
 * isActive=false: Excel'e gitmez ama silinmez (geçmiş kayıt).
 *
 * shareStock=true (default): Excel'de bu listing'e tam mainStock yazılır
 *   (çoklu listing varsa her birine aynı stok → max satış, oversold riski).
 * shareStock=false: Excel'de bu listing'e 0 yazılır (sadece primary listing
 *   tam stok alır → eski listing dürüstçe ölür).
 */
model ProductMarketplaceListing {
  id            Int @id @default(autoincrement())
  productId     Int
  marketplaceId Int

  // Marketplace'teki kimlik (Excel kolonlarına direkt karşılık gelir)
  barcode       String?  // TY barkod → Dopigo Excel "barkod/gtin" kolonu
  sku           String?  // Dopigo internal SKU → Excel "sku" kolonu (eşleştirme key'i)
  supplierSku   String?  // Dopigo Tedarikçi SKU → Excel "Tedarikçi SKU" kolonu
  externalCode  String?  // gelecekte TY contentId vs için (opsiyonel meta)

  // Davranış
  isPrimary    Boolean @default(true)
  isActive     Boolean @default(true)
  shareStock   Boolean @default(true)

  // Metadata (ileride scraping ile dolar — opsiyonel)
  reviewCount  Int?
  rating       Decimal? @db.Decimal(3, 2)

  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  marketplace Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  // Aynı ürünün aynı marketplace'te aynı barkodu 2 kez olamaz.
  // Barkod null olabilir (sadece SKU ile listelenmiş Dopigo gibi).
  @@unique([productId, marketplaceId, barcode])
  @@index([productId])
  @@index([marketplaceId])
  @@index([barcode])
}

/**
 * Trendyol-relative price floor (marka × marketplace)
 *
 * Mantık: Trendyol fiyatı her marketplace için referans/zemin görevi görür.
 * Bir markanın bir marketplace'teki fiyatı, TY fiyatının belirli bir oranının
 * altına inmemeli. Skinceuticals + Hepsiburada için multiplier=0.9375 → HB fiyatı
 * en az TY×0.9375 olur. TY=8000 ise HB minimum 7500 TL.
 *
 * Trendyol için ayrıca kayıt tutulmaz (kendi referans). Diğer marketplace'ler
 * için kayıt yoksa floor uygulanmaz (klasik formül kazanır).
 *
 * Multiplier > 1.0 → premium (TY üstü, ör 1.05 = TY'nin %5 üstü)
 * Multiplier = 1.0 → eşit
 * Multiplier < 1.0 → kontrollü indirim (ör 0.9375 = TY'nin %93.75'i)
 *
 * Kullanım yeri: dopigo-sync.ts (Dopigo Excel export). İleride
 * price-recommendation.ts'e de eklenebilir.
 */
model BrandMarketplaceFloor {
  id            Int @id @default(autoincrement())
  brandId       Int
  marketplaceId Int

  // TY fiyatına göre minimum çarpan (örn 0.9375 → TY × 0.9375 floor).
  // Bu marketplace için fiyat bu değerin altına inmez.
  multiplier Decimal @db.Decimal(6, 4)

  isEnabled Boolean @default(true)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand       Brand       @relation(fields: [brandId], references: [id], onDelete: Cascade)
  marketplace Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  @@unique([brandId, marketplaceId])
  @@index([brandId])
  @@index([marketplaceId])
}

model Product {
  id         Int @id @default(autoincrement())
  pharmacyId Int @default(1)

  name           String
  primaryBarcode String      @unique
  supplierBarcode String?    // Tedarikçi/distribütör barkodu — brand catalog upload + Dopigo eşleşme yedeği
  // Pazaryeri-bazlı kodlar (manuel eşleştirme ile gelir, kanal-bazlı görünüm için)
  trendyolBarcode String?    // Trendyol'da listelenen ürünün GTIN/barkodu
  dopigoBarcode   String?    // Dopigo Tedarikçi Barkodu (genelde TY ile aynı GTIN)
  dopigoSku       String?    // Dopigo internal SKU (örn. SKN-CTCLS-G-NTR-3)
  brandId        Int
  categoryId     Int
  subcategoryId  Int?
  vatRate        Decimal     @db.Decimal(5, 2)
  productType    ProductType @default(SINGLE)

  // Ana depo
  mainStock         Int      @default(0)
  mainPurchasePrice Decimal? @db.Decimal(14, 4) // KDV dahil, iskontolar dahil (weighted avg)
  // mainPurchasePrice'ın son değişim zamanı — bayat öneri (recommendedPrice) kontrolü için.
  // ProductMarketplacePrice.recommendedAt < bu tarih ise öneri bayat → formula'ya düş.
  mainPriceUpdatedAt DateTime?

  // Cadde (eczane)
  streetStock         Int      @default(0)
  streetPurchasePrice Decimal? @db.Decimal(14, 4) // KDV hariç, fatura altı iskonto dahil
  streetPharmacyCode  String? // cadde upload'ından gelen eczane ürün kodu (ileride kullanılabilir)
  pharmacyProductCode String? @unique // EZC master kodu — alış eşleştirme için

  // Referans fiyat
  psf Decimal? @db.Decimal(14, 4)

  // Meta
  manufacturer      String?
  minStock          Int           @default(0)
  shelf             String?
  status            ProductStatus @default(ACTIVE)
  nearestExpiration DateTime?
  paoMonths         Int?

  // Takas
  exchangeStock Int @default(0)

  // Set-specific
  setSku           String?  @unique
  setExtraDiscount Decimal? @default(0) @db.Decimal(14, 4)

  // Hediye ürün için minimum satış fiyatı (alış 1 TL gibi olduğunda
  // formül anlamsız çıkar — bu manuel taban kullanılır)
  giftMinSalePrice Decimal? @db.Decimal(14, 4)

  // Trendyol Favorilenme — yıllık verilerin ağırlıklı ortalaması (cache)
  // YEARLY tipinde upload yapıldığında recompute edilir.
  // 0-100 arası normalize edilmiş skor — yüksek = köklü best-seller.
  lifetimeDemandScore     Decimal?  @db.Decimal(8, 4)
  lifetimeDemandUpdatedAt DateTime?

  // Not
  notes String?

  // Fatura autofill — son bilinen markadan eczaneye kesilmiş fatura no
  lastBrandInvoiceNumber String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand       Brand        @relation(fields: [brandId], references: [id])
  category    Category     @relation(fields: [categoryId], references: [id])
  subcategory Subcategory? @relation(fields: [subcategoryId], references: [id])

  barcodes                    ProductBarcode[]
  marketplacePrices           ProductMarketplacePrice[]
  marketplaceListings         ProductMarketplaceListing[]
  priceHistory                PriceHistory[]
  stockMovements              StockMovement[]
  exchanges                   Exchange[]
  setComponents               SetComponent[]               @relation("SetProduct")
  componentOfSets             SetComponent[]               @relation("ComponentProduct")
  competitorPriceObservations CompetitorPriceObservation[]
  mergeHistory                ProductMergeHistory[]
  priceListItems              BrandPriceList[]
  purchaseOrderItems          PurchaseOrderItem[]
  campaignProducts            CampaignProduct[]
  campaignSales               CampaignSale[]
  favoriteSnapshots           TrendyolFavoriteSnapshot[]
  trendyolListings            TrendyolListing[]
  dopigoOrderItems            DopigoOrderItem[]
  commissionTariffs           CommissionTariff[]

  @@index([pharmacyId])
  @@index([brandId])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([status])
  @@index([primaryBarcode])
  @@index([supplierBarcode])
  @@index([trendyolBarcode])
  @@index([dopigoBarcode])
  @@index([dopigoSku])
  @@index([productType])
}

model ProductBarcode {
  id        Int           @id @default(autoincrement())
  productId Int
  barcode   String        @unique
  isPrimary Boolean       @default(false)
  source    BarcodeSource @default(MANUAL) // hangi kanal ekledi
  note      String?
  createdAt DateTime      @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([barcode])
  @@index([source])
}

enum BarcodeSource {
  MANUAL          // kullanıcı eli ile ekledi
  ERP_PRIMARY     // Product.primaryBarcode mirror (backfill)
  TRENDYOL_AUDIT  // /barkod-eslestirme'de Trendyol tarafından eklendi
  DOPIGO_AUDIT    // /barkod-eslestirme'de Dopigo tarafından eklendi
  IMPORT          // Excel/CSV import'tan
}

model ProductMarketplacePrice {
  id               Int      @id @default(autoincrement())
  productId        Int
  marketplaceId    Int
  calculatedPrice  Decimal  @db.Decimal(14, 4)
  manualOverride   Decimal? @db.Decimal(14, 4)
  lastCalculatedAt DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // BuyBox tabanli akilli oneri motoru ciktilari
  recommendedPrice    Decimal?  @db.Decimal(14, 4)
  recommendationBasis Json?
  recommendedAt       DateTime?

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  marketplace Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  @@unique([productId, marketplaceId])
  @@index([marketplaceId])
}

model SetComponent {
  id           Int @id @default(autoincrement())
  setProductId Int
  componentId  Int
  quantity     Int @default(1)

  setProduct Product @relation("SetProduct", fields: [setProductId], references: [id], onDelete: Cascade)
  component  Product @relation("ComponentProduct", fields: [componentId], references: [id])

  @@unique([setProductId, componentId])
  @@index([componentId])
}

model Counterparty {
  id        Int              @id @default(autoincrement())
  name      String
  type      CounterpartyType @default(PHARMACY)
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  exchanges      Exchange[]
  stockMovements StockMovement[]
  entrySessions  EntrySession[]
  purchaseInvoices PurchaseInvoice[]
}

model Exchange {
  id             Int               @id @default(autoincrement())
  direction      ExchangeDirection
  counterpartyId Int
  productId      Int
  quantity       Int

  // Senaryo A split: aldığımız qty'nin kaç tanesi stoğa girecek (geri kalan pass-through satışa)
  quantityToStock Int @default(0)

  // Stoğa girenin birim alış fiyatı (A için). B/C'de referans değer olarak kullanılabilir.
  unitPrice Decimal? @db.Decimal(14, 4)

  // Senaryo C'de farklı ürünle karşılık: verilen kayıt ile gelen kayıt birbirine bağlanır
  linkedExchangeId Int?

  expirationDate DateTime?
  addedToStock   Boolean        @default(false)
  status         ExchangeStatus @default(PENDING)
  note           String?
  createdAt      DateTime       @default(now())
  completedAt    DateTime?
  updatedAt      DateTime       @updatedAt

  counterparty Counterparty @relation(fields: [counterpartyId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])

  linkedExchange Exchange?  @relation("LinkedExchange", fields: [linkedExchangeId], references: [id])
  linkedBy       Exchange[] @relation("LinkedExchange")

  @@index([direction])
  @@index([status])
  @@index([counterpartyId])
  @@index([productId])
  @@index([linkedExchangeId])
}

model EntrySession {
  id          Int         @id @default(autoincrement())
  generalNote String?
  source      EntrySource @default(PURCHASE)

  // Cari (kaynak eczane)
  counterpartyId Int?

  // Marka fatura (markadan eczaneye kesilen — genelde biliniyor)
  brandInvoiceNumber String?

  // Eczane fatura (bize kesilen — ay sonu kesinleşir)
  pharmacyInvoiceLabel         String? // "2026 NİSAN SKINCEUTICALS"
  pharmacyInvoiceNumber        String? // kesin no (başta null)
  pharmacyInvoicePending       Boolean @default(false)
  pharmacyInvoiceExpectedMonth String? // "2026-04"

  userId    String?
  createdAt DateTime @default(now())

  counterparty Counterparty?   @relation(fields: [counterpartyId], references: [id])
  movements    StockMovement[]

  @@index([counterpartyId])
  @@index([pharmacyInvoicePending])
}

model StockMovement {
  id             Int          @id @default(autoincrement())
  productId      Int
  type           MovementType
  quantity       Int // her zaman pozitif; yön `type` ile belirlenir
  unitPrice      Decimal?     @db.Decimal(14, 4)
  counterpartyId Int?
  entrySessionId Int?
  note           String?
  expirationDate DateTime?
  source         EntrySource?

  // Fatura — ürün bazlı override (null ise seansın faturası geçerli)
  brandInvoiceNumber           String? // markadan eczaneye kesilen (referans)
  pharmacyInvoiceLabel         String?
  pharmacyInvoiceNumber        String?
  pharmacyInvoicePending       Boolean @default(false)
  pharmacyInvoiceExpectedMonth String?

  createdAt DateTime @default(now())
  createdBy String?

  product      Product       @relation(fields: [productId], references: [id])
  counterparty Counterparty? @relation(fields: [counterpartyId], references: [id])
  entrySession EntrySession? @relation(fields: [entrySessionId], references: [id])

  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@index([pharmacyInvoicePending])
  @@index([pharmacyInvoiceExpectedMonth])
}

model PriceHistory {
  id           Int       @id @default(autoincrement())
  productId    Int
  priceType    PriceType
  oldValue     Decimal?  @db.Decimal(14, 4)
  newValue     Decimal   @db.Decimal(14, 4)
  enteredValue Decimal?  @db.Decimal(14, 4) // Üründe fiilen girilen birim fiyat (ör. giriş ekranında girilen fatura birim fiyatı); weighted avg farklı olabilir
  reason       String?
  changedAt    DateTime  @default(now())
  changedBy    String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([priceType])
  @@index([changedAt])
}

model PharmacyDataUpload {
  id              Int      @id @default(autoincrement())
  filename        String
  rowCount        Int
  newProducts     Int      @default(0)
  updatedProducts Int      @default(0)
  skippedRows     Int      @default(0)
  conflictsJson   Json?
  uploadedAt      DateTime @default(now())
  uploadedBy      String?
}

// ---------- Enums ----------
enum UserRole {
  ADMIN
  MANAGER
  STAFF
  SALES
}

enum ProductType {
  SINGLE
  SET
  GIFT
}

enum ProductStatus {
  ACTIVE
  PASSIVE
}

enum CounterpartyType {
  PHARMACY
  DISTRIBUTOR
  INDIVIDUAL
}

enum ExchangeDirection {
  GIVEN
  RECEIVED
}

enum ExchangeStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum EntrySource {
  PURCHASE
  RETURN
}

enum MovementType {
  IN
  OUT
  EXCHANGE_OUT
  EXCHANGE_IN
  EXCHANGE_COMPLETE
  ADJUSTMENT
  SET_CONSUMPTION
}

enum PriceType {
  MAIN_PURCHASE
  PSF
  STREET_PURCHASE
  SALE_CALCULATED
}


// ===== Pazaryeri Entegrasyonları =====

/// Trendyol Seller API ayarları — singleton (id=1)
model TrendyolConfig {
  id         Int      @id @default(1)
  pharmacyId Int      @default(1)

  supplierId String   // Satıcı ID (Trendyol panelinden)
  apiKey     String   // API Key
  apiSecret  String   // API Secret (şifresiz tutuluyor; ileride encryption eklenecek)

  // Hangi ortam? prod / stage
  environment String  @default("prod")

  // Aktif mi? Pasifse istek atılmaz
  isActive Boolean @default(true)

  // Son test zamanı + sonucu
  lastTestedAt DateTime?
  lastTestOk   Boolean?
  lastTestNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Dopigo API konfigürasyonu — SADECE OKUMA için kullanılır (GET only).
/// CLAUDE.md: Dopigo'ya hiçbir veri POST/PUT/PATCH/DELETE gönderilmez.
model DopigoConfig {
  id         Int      @id @default(1)
  pharmacyId Int      @default(1)

  apiToken   String   // DRF tarzı: "Authorization: Token <apiToken>"
  baseUrl    String   @default("https://panel.dopigo.com")
  isActive   Boolean  @default(true)

  lastTestedAt DateTime?
  lastTestOk   Boolean?
  lastTestNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Dopigo'dan çekilen sipariş — read-only snapshot.
model DopigoOrder {
  id Int @id @default(autoincrement())

  // Dopigo tarafındaki ID (unique)
  dopigoOrderId BigInt @unique

  // Marketplace bilgisi (Dopigo'nun gönderdiği)
  serviceName    String   // "trendyol", "hepsiburada", "farmazon", "store"...
  salesChannel   String   // "trendyol", "hepsiburada"... (lower-case)
  serviceOrderId String?  // ör. Trendyol order code "3833483689"
  serviceValue   String?  // ör. "11216996303-3833483689"

  // İçerideki Marketplace tablosuyla bağ (varsa). Yeni kanal görürsek null kalır.
  marketplaceId Int?
  marketplace   Marketplace? @relation(fields: [marketplaceId], references: [id], onDelete: SetNull)

  // Tarihler
  serviceCreatedAt DateTime  // Dopigo "service_created" — esas tarihimiz
  shippedAt        DateTime?

  // Tutarlar
  total       Decimal  @db.Decimal(12, 2) // Toplam (KDV dahil)
  serviceFee  Decimal? @db.Decimal(12, 2) // Dopigo'nun service_fee
  discount    Decimal? @db.Decimal(12, 2)

  paymentType String? // "cc", vb.
  status      String  // "waiting_shipment", "shipped", "cancelled", ... (Dopigo'nun ham status'u)
  archived    Boolean @default(false)

  // Türetilmiş durum (UI'da kullanılır):
  //  SUCCESS  — shipped + invoice_deleted=false
  //  CANCELLED — status=cancelled
  //  RETURNED  — shipped + invoice_deleted=true (iade)
  //  WAITING   — waiting_shipment
  //  OTHER     — bilinmeyen
  derivedStatus String @default("OTHER")

  // Dopigo raw json'dan: invoice_deleted=true ise sipariş büyük ihtimalle iade.
  invoiceDeleted Boolean @default(false)
  invoiceNumber  String?

  notes       String?

  // Müşteri bilgisi (denormalize, tekrar müşteri tablosu lazım olursa ayrı tablo)
  customerName    String?
  customerCity    String?
  customerDistrict String?
  customerEmail   String?

  // Senkron meta
  fetchedAt DateTime @default(now())
  rawJson   Json     // ham API cevabı (debugging için)

  items DopigoOrderItem[]
  trendyolReconciliation TrendyolOrderReconciliation?

  @@index([serviceCreatedAt])
  @@index([salesChannel, serviceCreatedAt])
  @@index([status])
  @@index([derivedStatus])
  @@index([marketplaceId])
  @@index([serviceOrderId])
}

/// Sipariş kalemi (ürün satırı). Bizim Product ile eşleştirme burada.
model DopigoOrderItem {
  id Int @id @default(autoincrement())

  dopigoItemId BigInt @unique
  orderId      Int
  order        DopigoOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Dopigo verisi
  serviceItemId    String?  // Trendyol line item id (ör. "5489388389")
  serviceProductId String?  // genelde barkod ya da TY product id
  sku              String?  // Dopigo'daki SKU (lojistik kod)
  foreignSku       String?  // linked_product.foreign_sku — genelde BARKOD
  barcode          String?  // ham barkod
  productName      String

  amount    Int            // adet
  price     Decimal        @db.Decimal(12, 2) // satır toplamı (price * amount değil, line total — Dopigo öyle veriyor)
  unitPrice Decimal?       @db.Decimal(12, 2)
  taxRatio  Int?           // KDV %
  itemStatus String?       // "approved", "cancelled", ...

  // Bizim Product'a eşleşme
  productId Int?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  // Eşleşme metodu (audit için)
  matchMethod String?  // "BARCODE_EXACT" | "FOREIGN_SKU_EXACT" | "DOPIGO_SKU" | "MANUAL" | "NONE"
  matchedAt   DateTime?

  // Hediye/Set işareti — analiz raporunda ayrı göstermek için
  productType String?  // SINGLE | SET | GIFT (snapshot)

  @@index([orderId])
  @@index([productId])
  @@index([barcode])
  @@index([foreignSku])
  @@index([matchMethod])
}

/// Sipariş senkron çalıştırma logu — kontrol + audit için.
/// (Dopigo Excel yükleme için ayrı model var: DopigoSyncRun)
model DopigoOrderSyncRun {
  id Int @id @default(autoincrement())

  startedAt   DateTime @default(now())
  finishedAt  DateTime?

  // Hangi tarih aralığı çekildi
  rangeFrom DateTime?
  rangeTo   DateTime?

  totalFetched Int     @default(0)
  totalCreated Int     @default(0)
  totalUpdated Int     @default(0)
  totalMatched Int     @default(0) // bu run'da product eşleşmesi yapılan item sayısı

  status       String  @default("RUNNING") // RUNNING | SUCCESS | FAILED
  errorMessage String?

  triggeredBy String? // "MANUAL" | "CRON" | "INITIAL_BACKFILL"
}

/// Ay sonu raporu için — kullanıcının her marketplace × ay için elle girdiği gerçek giderler.
/// Mod 2 (detaylı rapor) bu verilerle gerçek net karı hesaplar.
/// Bu kayıt yoksa Mod 1 (tahmini) kullanılır.
model MarketplaceMonthlyExpense {
  id              Int      @id @default(autoincrement())
  marketplaceId   Int
  marketplace     Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  // Ayın ilk günü (UTC midnight)
  month DateTime

  // Kullanıcının panelden bakıp girdiği gerçek değerler
  commissionPaid  Decimal? @db.Decimal(12, 2)
  shippingPaid    Decimal? @db.Decimal(12, 2)
  withholdingPaid Decimal? @db.Decimal(12, 2)
  returnCosts     Decimal? @db.Decimal(12, 2)
  adSpend         Decimal? @db.Decimal(12, 2)
  otherExpenses   Decimal? @db.Decimal(12, 2)

  notes String?

  enteredAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  enteredBy String?

  @@unique([marketplaceId, month])
  @@index([month])
}

/// BuyBox/rakip fiyat gözlemi — zaman içinde fiyat hareketini izlemek için
model CompetitorPriceObservation {
  id        Int      @id @default(autoincrement())
  productId Int

  source           String   // "TRENDYOL_BUYBOX"
  buyboxPrice      Decimal  @db.Decimal(12, 2)
  buyboxOrder      Int?     // 1 = bizdeyiz, >1 = rakip BuyBox'ta
  hasMultipleSeller Boolean @default(false)
  // Bizim o anki fiyatımız (referans için saklıyoruz)
  ourPrice Decimal? @db.Decimal(12, 2)

  observedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, observedAt])
  @@index([source, observedAt])
}

