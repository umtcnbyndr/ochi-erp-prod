  /** Görsel için ürün adı (snapshot) */
  name          String
  purchasePrice Decimal  @db.Decimal(14, 4)  // KDV dahil alış
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String?  // userId

  @@unique([sku, barcode])
  @@index([sku])
  @@index([barcode])
}

