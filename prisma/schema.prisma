// Ochi ERP — Prisma Schema
// Pharmacy ERP with marketplace-ready pricing engine

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth.js Tables ----------
model User {
  id            String    @id @default(cuid())
  username      String    @unique
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  role          UserRole  @default(STAFF)
  isActive      Boolean   @default(true)
  pharmacyId    Int       @default(1)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  permissions UserPermission[]
  panelNotes  PanelNote[]

  @@index([pharmacyId])
  @@index([username])
}

/// Panel sayfasındaki kişisel notlar / yapılacaklar.
/// Her kullanıcının kendi notları olur. Basit todo: text + done flag.
model PanelNote {
  id        Int      @id @default(autoincrement())
  userId    String
  text      String   @db.Text
  done      Boolean  @default(false)
  pinned    Boolean  @default(false) // önemli notları üste sabitle
  createdAt DateTime @default(now())
  doneAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, done])
  @@index([userId, pinned, createdAt])
}

// Kullanıcı bazlı modül izinleri
model UserPermission {
  id       Int     @id @default(autoincrement())
  userId   String
  module   String  // modül key'i (örn: "urunler", "markalar", "raporlar")
  canView  Boolean @default(false)
  canEdit  Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Core ERP Tables ----------
model Pharmacy {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Brand {
  id         Int      @id @default(autoincrement())
  pharmacyId Int      @default(1)
  name       String   @unique
  aliases    String[] @default([]) // Eski isimler / alternatif yazımlar — rename geçmişi, import'ta eşleme için

  // İskontolar (% — yüzde olarak tutulur, örn. 10 = %10)
  invoiceDiscount1 Decimal @default(0) @db.Decimal(5, 2)
  invoiceDiscount2 Decimal @default(0) @db.Decimal(5, 2)
  invoiceDiscount3 Decimal @default(0) @db.Decimal(5, 2)
  yearEndDiscount1 Decimal @default(0) @db.Decimal(5, 2)
  yearEndDiscount2 Decimal @default(0) @db.Decimal(5, 2)
  yearEndDiscount3 Decimal @default(0) @db.Decimal(5, 2)

  pharmacyMargin    Decimal @default(0) @db.Decimal(5, 2)
  pharmacyStockRule Int     @default(0)
  // Açılacak maksimum miktar — null = "üstünün TAMAMINI aç" (mevcut davranış)
  // Sayı = "kural üstünden EN ÇOK bu kadar aç" (örn 1 → sadece 1 aç).
  // Az hareketli ürünlerde gereksiz açma yapmamak için.
  pharmacyOpenAmount Int?

  // Pazaryeri hedef kar marjı (opsiyonel, % — örn. 30 = %30).
  // Doluysa marketplace.targetProfit'i override eder. Tüm pazar yerlerinde geçerli.
  // Boşsa marketplace'in kendi hedef karı kullanılır.
  targetProfit Decimal? @db.Decimal(5, 2)

  // BuyBox bazlı fiyat önerisinde rakibin ne kadar altına ineceğimiz (TL — sabit).
  // 0 = aynı fiyat, 5 = rakip fiyatı - 5 TL. priceUndercutBufferPct varsa o öncelikli.
  priceUndercutBuffer Decimal @default(0) @db.Decimal(10, 2)
  // BuyBox altına inerken yüzde tampon (orantılı). 5 = rakip fiyatı × 0.95.
  // Hem TL hem % varsa: % öncelikli (orantılı koruma daha güvenli).
  priceUndercutBufferPct Decimal @default(0) @db.Decimal(5, 2)

  distributorInfo String?
  contactInfo     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
  priceListItems BrandPriceList[]
  campaigns      Campaign[]
  marketplaceFloors BrandMarketplaceFloor[]

  @@index([pharmacyId])
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  aliases   String[] @default([]) // Eski isimler — rename geçmişi, import'ta eşleme için
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subcategories Subcategory[]
  products      Product[]
}

model Subcategory {
  id         Int      @id @default(autoincrement())
  name       String
  aliases    String[] @default([]) // Eski isimler — rename geçmişi
  categoryId Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([name, categoryId])
  @@index([categoryId])
}

model Marketplace {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  commissionRate Decimal  @default(0) @db.Decimal(5, 2) // %
  shippingCost   Decimal  @default(0) @db.Decimal(10, 2) // TL sabit
  // Ek maliyet (TL sabit). Formülde kargo gibi paya eklenir.
  // Örn: ambalaj ücreti, return işlem ücreti, vs.
  extraCost      Decimal  @default(0) @db.Decimal(10, 2)
  withholdingTax Decimal  @default(0) @db.Decimal(5, 2) // stopaj %
  targetProfit   Decimal  @default(0) @db.Decimal(5, 2) // hedef kar %
  // Brand seviyesinde tampon yoksa kullanılır (TL — sabit)
  defaultUndercutBuffer Decimal? @db.Decimal(10, 2)
  // Brand seviyesinde tampon yoksa kullanılır (% — orantılı). % öncelikli.
  defaultUndercutBufferPct Decimal? @db.Decimal(5, 2)
  // BuyBox altına inerken min kar tabanı (%). Boşsa targetProfit kullanılır.
  // Örn: targetProfit=25 ama floor=10 → BuyBox bazlı öneri %10 kar tabanına kadar düşebilir.
  minProfitFloor Decimal? @db.Decimal(5, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  prices ProductMarketplacePrice[]
  brandFloors BrandMarketplaceFloor[]
  listings ProductMarketplaceListing[]
}

/**
 * Aynı ürünün bir marketplace'teki çoklu listing'leri.
 *
 * Senaryo: Mustela aynı 50ml kremi için TY'de 2 farklı barkodla listelemiş —
 * birinde 10 yorum (eski), birinde 500 yorum (yeni). Biz ERP'de tek ürün
 * tutuyoruz, ama Dopigo Excel export'ta her listing için ayrı satır gerekli.
 *
 * Stok ortak (Product.mainStock). Fiyat ortak (ProductMarketplacePrice).
 * Listing yalnız Dopigo Excel export'unda multi-row üretmek + BuyBox'ı
 * ayrı çekmek için kullanılır.
 *
 * isPrimary: birden fazla varsa default/anchor olarak kullanılır
 * (BuyBox sync, recommendation engine, vs).
 *
 * isActive=false: Excel'e gitmez ama silinmez (geçmiş kayıt).
 *
 * shareStock=true (default): Excel'de bu listing'e tam mainStock yazılır
 *   (çoklu listing varsa her birine aynı stok → max satış, oversold riski).
 * shareStock=false: Excel'de bu listing'e 0 yazılır (sadece primary listing
 *   tam stok alır → eski listing dürüstçe ölür).
 */
model ProductMarketplaceListing {
  id            Int @id @default(autoincrement())
  productId     Int
  marketplaceId Int

  // Marketplace'teki kimlik (Excel kolonlarına direkt karşılık gelir)
  barcode       String?  // TY barkod → Dopigo Excel "barkod/gtin" kolonu
  sku           String?  // Dopigo internal SKU → Excel "sku" kolonu (eşleştirme key'i)
  supplierSku   String?  // Dopigo Tedarikçi SKU → Excel "Tedarikçi SKU" kolonu
  externalCode  String?  // gelecekte TY contentId vs için (opsiyonel meta)

  // Davranış
  isPrimary    Boolean @default(true)
  isActive     Boolean @default(true)
  shareStock   Boolean @default(true)

  // Metadata (ileride scraping ile dolar — opsiyonel)
  reviewCount  Int?
  rating       Decimal? @db.Decimal(3, 2)

  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  marketplace Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  // Aynı ürünün aynı marketplace'te aynı barkodu 2 kez olamaz.
  // Barkod null olabilir (sadece SKU ile listelenmiş Dopigo gibi).
  @@unique([productId, marketplaceId, barcode])
  @@index([productId])
  @@index([marketplaceId])
  @@index([barcode])
}

/**
 * Trendyol-relative price floor (marka × marketplace)
 *
 * Mantık: Trendyol fiyatı her marketplace için referans/zemin görevi görür.
 * Bir markanın bir marketplace'teki fiyatı, TY fiyatının belirli bir oranının
 * altına inmemeli. Skinceuticals + Hepsiburada için multiplier=0.9375 → HB fiyatı
 * en az TY×0.9375 olur. TY=8000 ise HB minimum 7500 TL.
 *
 * Trendyol için ayrıca kayıt tutulmaz (kendi referans). Diğer marketplace'ler
 * için kayıt yoksa floor uygulanmaz (klasik formül kazanır).
 *
 * Multiplier > 1.0 → premium (TY üstü, ör 1.05 = TY'nin %5 üstü)
 * Multiplier = 1.0 → eşit
 * Multiplier < 1.0 → kontrollü indirim (ör 0.9375 = TY'nin %93.75'i)
 *
 * Kullanım yeri: dopigo-sync.ts (Dopigo Excel export). İleride
 * price-recommendation.ts'e de eklenebilir.
 */
model BrandMarketplaceFloor {
  id            Int @id @default(autoincrement())
  brandId       Int
  marketplaceId Int

  // TY fiyatına göre minimum çarpan (örn 0.9375 → TY × 0.9375 floor).
  // Bu marketplace için fiyat bu değerin altına inmez.
  multiplier Decimal @db.Decimal(6, 4)

  isEnabled Boolean @default(true)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand       Brand       @relation(fields: [brandId], references: [id], onDelete: Cascade)
  marketplace Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  @@unique([brandId, marketplaceId])
  @@index([brandId])
  @@index([marketplaceId])
}

model Product {
  id         Int @id @default(autoincrement())
  pharmacyId Int @default(1)

  name           String
  primaryBarcode String      @unique
  supplierBarcode String?    // Tedarikçi/distribütör barkodu — brand catalog upload + Dopigo eşleşme yedeği
  // Pazaryeri-bazlı kodlar (manuel eşleştirme ile gelir, kanal-bazlı görünüm için)
  trendyolBarcode String?    // Trendyol'da listelenen ürünün GTIN/barkodu
  dopigoBarcode   String?    // Dopigo Tedarikçi Barkodu (genelde TY ile aynı GTIN)
  dopigoSku       String?    // Dopigo internal SKU (örn. SKN-CTCLS-G-NTR-3)
  brandId        Int
  categoryId     Int
  subcategoryId  Int?
  vatRate        Decimal     @db.Decimal(5, 2)
  productType    ProductType @default(SINGLE)

  // Ana depo
  mainStock         Int      @default(0)
  mainPurchasePrice Decimal? @db.Decimal(14, 4) // KDV dahil, iskontolar dahil (weighted avg)

  // Cadde (eczane)
  streetStock         Int      @default(0)
  streetPurchasePrice Decimal? @db.Decimal(14, 4) // KDV hariç, fatura altı iskonto dahil
  streetPharmacyCode  String? // cadde upload'ından gelen eczane ürün kodu (ileride kullanılabilir)
  pharmacyProductCode String? @unique // EZC master kodu — alış eşleştirme için

  // Referans fiyat
  psf Decimal? @db.Decimal(14, 4)

  // Meta
  manufacturer      String?
  minStock          Int           @default(0)
  shelf             String?
  status            ProductStatus @default(ACTIVE)
  nearestExpiration DateTime?
  paoMonths         Int?

  // Takas
  exchangeStock Int @default(0)

  // Set-specific
  setSku           String?  @unique
  setExtraDiscount Decimal? @default(0) @db.Decimal(14, 4)

  // Hediye ürün için minimum satış fiyatı (alış 1 TL gibi olduğunda
  // formül anlamsız çıkar — bu manuel taban kullanılır)
  giftMinSalePrice Decimal? @db.Decimal(14, 4)

  // Trendyol Favorilenme — yıllık verilerin ağırlıklı ortalaması (cache)
  // YEARLY tipinde upload yapıldığında recompute edilir.
  // 0-100 arası normalize edilmiş skor — yüksek = köklü best-seller.
  lifetimeDemandScore     Decimal?  @db.Decimal(8, 4)
  lifetimeDemandUpdatedAt DateTime?

  // Not
  notes String?

  // Fatura autofill — son bilinen markadan eczaneye kesilmiş fatura no
  lastBrandInvoiceNumber String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand       Brand        @relation(fields: [brandId], references: [id])
  category    Category     @relation(fields: [categoryId], references: [id])
  subcategory Subcategory? @relation(fields: [subcategoryId], references: [id])

  barcodes                    ProductBarcode[]
  marketplacePrices           ProductMarketplacePrice[]
  marketplaceListings         ProductMarketplaceListing[]
  priceHistory                PriceHistory[]
  stockMovements              StockMovement[]
  exchanges                   Exchange[]
  setComponents               SetComponent[]               @relation("SetProduct")
  componentOfSets             SetComponent[]               @relation("ComponentProduct")
  competitorPriceObservations CompetitorPriceObservation[]
  mergeHistory                ProductMergeHistory[]
  priceListItems              BrandPriceList[]
  purchaseOrderItems          PurchaseOrderItem[]
  campaignProducts            CampaignProduct[]
  campaignSales               CampaignSale[]
  favoriteSnapshots           TrendyolFavoriteSnapshot[]
  trendyolListings            TrendyolListing[]

  @@index([pharmacyId])
  @@index([brandId])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([status])
  @@index([primaryBarcode])
  @@index([supplierBarcode])
  @@index([trendyolBarcode])
  @@index([dopigoBarcode])
  @@index([dopigoSku])
  @@index([productType])
}

model ProductBarcode {
  id        Int           @id @default(autoincrement())
  productId Int
  barcode   String        @unique
  isPrimary Boolean       @default(false)
  source    BarcodeSource @default(MANUAL) // hangi kanal ekledi
  note      String?
  createdAt DateTime      @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([barcode])
  @@index([source])
}

enum BarcodeSource {
  MANUAL          // kullanıcı eli ile ekledi
  ERP_PRIMARY     // Product.primaryBarcode mirror (backfill)
  TRENDYOL_AUDIT  // /barkod-eslestirme'de Trendyol tarafından eklendi
  DOPIGO_AUDIT    // /barkod-eslestirme'de Dopigo tarafından eklendi
  IMPORT          // Excel/CSV import'tan
}

model ProductMarketplacePrice {
  id               Int      @id @default(autoincrement())
  productId        Int
  marketplaceId    Int
  calculatedPrice  Decimal  @db.Decimal(14, 4)
  manualOverride   Decimal? @db.Decimal(14, 4)
  lastCalculatedAt DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // BuyBox tabanli akilli oneri motoru ciktilari
  recommendedPrice    Decimal?  @db.Decimal(14, 4)
  recommendationBasis Json?
  recommendedAt       DateTime?

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  marketplace Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  @@unique([productId, marketplaceId])
  @@index([marketplaceId])
}

model SetComponent {
  id           Int @id @default(autoincrement())
  setProductId Int
  componentId  Int
  quantity     Int @default(1)

  setProduct Product @relation("SetProduct", fields: [setProductId], references: [id], onDelete: Cascade)
  component  Product @relation("ComponentProduct", fields: [componentId], references: [id])

  @@unique([setProductId, componentId])
  @@index([componentId])
}

model Counterparty {
  id        Int              @id @default(autoincrement())
  name      String
  type      CounterpartyType @default(PHARMACY)
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  exchanges      Exchange[]
  stockMovements StockMovement[]
  entrySessions  EntrySession[]
}

model Exchange {
  id             Int               @id @default(autoincrement())
  direction      ExchangeDirection
  counterpartyId Int
  productId      Int
  quantity       Int

  // Senaryo A split: aldığımız qty'nin kaç tanesi stoğa girecek (geri kalan pass-through satışa)
  quantityToStock Int @default(0)

  // Stoğa girenin birim alış fiyatı (A için). B/C'de referans değer olarak kullanılabilir.
  unitPrice Decimal? @db.Decimal(14, 4)

  // Senaryo C'de farklı ürünle karşılık: verilen kayıt ile gelen kayıt birbirine bağlanır
  linkedExchangeId Int?

  expirationDate DateTime?
  addedToStock   Boolean        @default(false)
  status         ExchangeStatus @default(PENDING)
  note           String?
  createdAt      DateTime       @default(now())
  completedAt    DateTime?
  updatedAt      DateTime       @updatedAt

  counterparty Counterparty @relation(fields: [counterpartyId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])

  linkedExchange Exchange?  @relation("LinkedExchange", fields: [linkedExchangeId], references: [id])
  linkedBy       Exchange[] @relation("LinkedExchange")

  @@index([direction])
  @@index([status])
  @@index([counterpartyId])
  @@index([productId])
  @@index([linkedExchangeId])
}

model EntrySession {
  id          Int         @id @default(autoincrement())
  generalNote String?
  source      EntrySource @default(PURCHASE)

  // Cari (kaynak eczane)
  counterpartyId Int?

  // Marka fatura (markadan eczaneye kesilen — genelde biliniyor)
  brandInvoiceNumber String?

  // Eczane fatura (bize kesilen — ay sonu kesinleşir)
  pharmacyInvoiceLabel         String? // "2026 NİSAN SKINCEUTICALS"
  pharmacyInvoiceNumber        String? // kesin no (başta null)
  pharmacyInvoicePending       Boolean @default(false)
  pharmacyInvoiceExpectedMonth String? // "2026-04"

  userId    String?
  createdAt DateTime @default(now())

  counterparty Counterparty?   @relation(fields: [counterpartyId], references: [id])
  movements    StockMovement[]

  @@index([counterpartyId])
  @@index([pharmacyInvoicePending])
}

model StockMovement {
  id             Int          @id @default(autoincrement())
  productId      Int
  type           MovementType
  quantity       Int // her zaman pozitif; yön `type` ile belirlenir
  unitPrice      Decimal?     @db.Decimal(14, 4)
  counterpartyId Int?
  entrySessionId Int?
  note           String?
  expirationDate DateTime?
  source         EntrySource?

  // Fatura — ürün bazlı override (null ise seansın faturası geçerli)
  brandInvoiceNumber           String? // markadan eczaneye kesilen (referans)
  pharmacyInvoiceLabel         String?
  pharmacyInvoiceNumber        String?
  pharmacyInvoicePending       Boolean @default(false)
  pharmacyInvoiceExpectedMonth String?

  createdAt DateTime @default(now())
  createdBy String?

  product      Product       @relation(fields: [productId], references: [id])
  counterparty Counterparty? @relation(fields: [counterpartyId], references: [id])
  entrySession EntrySession? @relation(fields: [entrySessionId], references: [id])

  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@index([pharmacyInvoicePending])
  @@index([pharmacyInvoiceExpectedMonth])
}

model PriceHistory {
  id           Int       @id @default(autoincrement())
  productId    Int
  priceType    PriceType
  oldValue     Decimal?  @db.Decimal(14, 4)
  newValue     Decimal   @db.Decimal(14, 4)
  enteredValue Decimal?  @db.Decimal(14, 4) // Üründe fiilen girilen birim fiyat (ör. giriş ekranında girilen fatura birim fiyatı); weighted avg farklı olabilir
  reason       String?
  changedAt    DateTime  @default(now())
  changedBy    String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([priceType])
  @@index([changedAt])
}

model PharmacyDataUpload {
  id              Int      @id @default(autoincrement())
  filename        String
  rowCount        Int
  newProducts     Int      @default(0)
  updatedProducts Int      @default(0)
  skippedRows     Int      @default(0)
  conflictsJson   Json?
  uploadedAt      DateTime @default(now())
  uploadedBy      String?
}

// ---------- Enums ----------
enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum ProductType {
  SINGLE
  SET
  GIFT
}

enum ProductStatus {
  ACTIVE
  PASSIVE
}

enum CounterpartyType {
  PHARMACY
  DISTRIBUTOR
  INDIVIDUAL
}

enum ExchangeDirection {
  GIVEN
  RECEIVED
}

enum ExchangeStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum EntrySource {
  PURCHASE
  RETURN
}

enum MovementType {
  IN
  OUT
  EXCHANGE_OUT
  EXCHANGE_IN
  EXCHANGE_COMPLETE
  ADJUSTMENT
  SET_CONSUMPTION
}

enum PriceType {
  MAIN_PURCHASE
  PSF
  STREET_PURCHASE
  SALE_CALCULATED
}


// ===== Pazaryeri Entegrasyonları =====

/// Trendyol Seller API ayarları — singleton (id=1)
model TrendyolConfig {
  id         Int      @id @default(1)
  pharmacyId Int      @default(1)

  supplierId String   // Satıcı ID (Trendyol panelinden)
  apiKey     String   // API Key
  apiSecret  String   // API Secret (şifresiz tutuluyor; ileride encryption eklenecek)

  // Hangi ortam? prod / stage
  environment String  @default("prod")

  // Aktif mi? Pasifse istek atılmaz
  isActive Boolean @default(true)

  // Son test zamanı + sonucu
  lastTestedAt DateTime?
  lastTestOk   Boolean?
  lastTestNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// BuyBox/rakip fiyat gözlemi — zaman içinde fiyat hareketini izlemek için
model CompetitorPriceObservation {
  id        Int      @id @default(autoincrement())
  productId Int

  source           String   // "TRENDYOL_BUYBOX"
  buyboxPrice      Decimal  @db.Decimal(12, 2)
  buyboxOrder      Int?     // 1 = bizdeyiz, >1 = rakip BuyBox'ta
  hasMultipleSeller Boolean @default(false)
  // Bizim o anki fiyatımız (referans için saklıyoruz)
  ourPrice Decimal? @db.Decimal(12, 2)

  observedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, observedAt])
  @@index([source, observedAt])
}

// ===== Pazaryeri Katalog Snapshot'ları =====

/// Trendyol'daki kendi satıcı kataloğumuzun snapshot'ı — son senkron sonucu.
/// `/barkod-eslestirme` audit'inde kullanılır, her sefer Trendyol'a hit etmesin diye.
model TrendyolListing {
  id           Int      @id @default(autoincrement())
  barcode      String   @unique
  productCode  String?  // Trendyol productCode (= "Model Kodu" varyantı)
  productMainId String? // Trendyol productMainId (= "Model Kodu" diğer varyantı, ds-/Skinceuticals.049 vs.)
  title        String
  brand        String?
  categoryName String?
  listPrice    Decimal? @db.Decimal(12, 2)
  salePrice    Decimal? @db.Decimal(12, 2)
  quantity     Int?
  approved     Boolean  @default(false)
  archived     Boolean  @default(false)
  rejected     Boolean  @default(false)
  onSale       Boolean  @default(false)
  rawJson      Json     // tam Trendyol response — ileride yeni alan eklenirse migration'sız
  fetchedAt    DateTime @default(now())

  // ERP Product eşleştirmesi (post-sync match ile doldurulur)
  // Excel.ModelKodu → TrendyolListing.productCode → productId tek-hop lookup için.
  productId         Int?
  productMatchedAt  DateTime?

  product Product? @relation(fields: [productId], references: [id])

  @@index([approved])
  @@index([productCode])
  @@index([productMainId])
  @@index([productId])
  @@index([fetchedAt])
}

/// Trendyol senkron çalıştırması (audit log)
model TrendyolSyncRun {
  id           Int       @id @default(autoincrement())
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  totalFetched Int       @default(0)
  totalPages   Int       @default(0)
  status       String    @default("RUNNING") // RUNNING | OK | FAILED
  errorMessage String?
}

/// Trendyol Favorilenme Raporu — yüklenen Excel periyodu
/// Aynı periyot tekrar yüklenirse upsert (eski snapshot'lar silinir, yenisi eklenir)
model FavoriteUploadRun {
  id                Int                @id @default(autoincrement())
  filename          String
  reportType        FavoriteReportType
  reportPeriodStart DateTime
  reportPeriodEnd   DateTime
  rowCount          Int                @default(0)
  matchedCount      Int                @default(0) // ERP'ye eşleşen satır sayısı
  uploadedAt        DateTime           @default(now())
  uploadedBy        String? // userId

  snapshots TrendyolFavoriteSnapshot[]

  @@unique([reportType, reportPeriodStart, reportPeriodEnd])
  @@index([reportPeriodEnd])
}

/// Trendyol favorilenme/görüntülenme metrikleri (zaman serisi)
/// Bir ürün × bir periyot = bir snapshot
model TrendyolFavoriteSnapshot {
  id          Int    @id @default(autoincrement())
  productCode String // Trendyol "Model Kodu" — TrendyolListing.productCode ile join
  productId   Int? // ERP Product (import sırasında TrendyolListing.barcode → Product join ile çözülür)

  // Periyot — FavoriteUploadRun ile eşleşir
  reportType        FavoriteReportType
  reportPeriodStart DateTime
  reportPeriodEnd   DateTime

  // Snapshot ürün bilgisi (Excel'den)
  productName  String
  brand        String?
  categoryName String?
  imageUrl     String?

  // Metrikler
  totalViews      Int     @default(0) // Toplam Görüntülenme
  grossFavorites  Int     @default(0) // Brüt Favorilenme (bu periyotta)
  activeFavorites Int     @default(0) // Aktif Favori (kümülatif - şu an)
  sellerViews     Int     @default(0) // Satıcı Görüntülenme
  cartAdds        Int     @default(0) // Sepete Eklenme
  orders          Int     @default(0) // Brüt Sipariş Adedi
  conversionRate  Decimal @default(0) @db.Decimal(7, 4) // 0.0500 = %5
  salesCount      Int     @default(0) // Brüt Satış Adedi
  grossRevenue    Decimal @default(0) @db.Decimal(14, 2) // Brüt Ciro TL

  // Computed: talep skoru (yüksek = popüler ürün)
  // demandScore = (cartAdds*5 + orders*20 + grossFavorites*1) / max(totalViews, 1)
  demandScore Decimal? @db.Decimal(10, 4)

  uploadId   Int
  importedAt DateTime @default(now())
  rawJson    Json // tam excel satırı

  product   Product?          @relation(fields: [productId], references: [id])
  uploadRun FavoriteUploadRun @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@unique([productCode, reportType, reportPeriodStart, reportPeriodEnd])
  @@index([productId])
  @@index([reportPeriodEnd])
  @@index([demandScore])
  @@index([uploadId])
}

enum FavoriteReportType {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  CUSTOM
}

/// Dopigo Excel'den çekilen ürünlerin snapshot'ı — eşleştirme için kalıcı.
model DopigoListing {
  id          Int      @id @default(autoincrement())
  barcode     String?
  sku         String?
  merchantSku String?
  name        String
  brand       String?
  rawRowJson  Json
  uploadedAt  DateTime @default(now())

  @@index([barcode])
  @@index([merchantSku])
}

/// Dopigo Excel yükleme çalıştırması (audit log)
model DopigoSyncRun {
  id         Int      @id @default(autoincrement())
  filename   String
  rowCount   Int
  uploadedAt DateTime @default(now())
}

// ---------- Ürün Birleştirme Geçmişi ----------
model ProductMergeHistory {
  id              Int      @id @default(autoincrement())
  targetProductId Int
  sourceProductId Int      // silinen ürünün orijinal ID'si
  sourceName      String   // silinen ürünün adı
  sourceBarcode   String   // silinen ürünün primary barkodu
  sourceSnapshot  Json     // silinen ürünün tüm verileri (geri alma için)
  mergedBarcodes  Json     // taşınan barkodlar listesi (string[])
  stockTransfer   Json     // { mainStock, streetStock, exchangeStock } transfer edilen
  status          MergeStatus @default(ACTIVE)
  mergedAt        DateTime @default(now())
  revertedAt      DateTime?

  targetProduct   Product  @relation(fields: [targetProductId], references: [id])

  @@index([targetProductId])
  @@index([sourceBarcode])
}

enum MergeStatus {
  ACTIVE    // birleştirme aktif
  REVERTED  // geri alındı
}

// ---------- Sipariş Sistemi ----------

/// Marka liste fiyatları — Excel'den yüklenir, sipariş hesabında başlangıç noktası
model BrandPriceList {
  id              Int      @id @default(autoincrement())
  brandId         Int
  productId       Int
  listPrice       Decimal  @db.Decimal(14, 4)  // marka liste fiyatı
  isVatIncluded   Boolean  @default(false)     // KDV dahil mi
  uploadedAt      DateTime @default(now())

  brand   Brand   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([brandId, productId])
  @@index([brandId])
  @@index([productId])
}

/// Marka liste fiyat yükleme audit log
model BrandPriceListUpload {
  id          Int      @id @default(autoincrement())
  brandId     Int
  filename    String
  rowCount    Int
  matchedCount Int     @default(0)
  isVatIncluded Boolean
  uploadedAt  DateTime @default(now())

  @@index([brandId])
}

/// Satın alma siparişi (distribütöre verilen)
model PurchaseOrder {
  id              Int      @id @default(autoincrement())
  /// Sipariş bir veya birden fazla markayı kapsayabilir
  brandIds        Int[]    @default([])
  status          PurchaseOrderStatus @default(DRAFT)

  /// Hesap parametreleri (snapshot)
  analysisDays    Int      @default(90)  // satış analizi için bakılan gün
  targetStockDays Int      @default(60)  // hedef stok günü

  /// Notlar
  note            String?

  /// Tutar özeti (cache — items'tan hesaplanır)
  totalListAmount Decimal  @default(0) @db.Decimal(14, 2)  // liste fiyat toplamı
  totalNetAmount  Decimal  @default(0) @db.Decimal(14, 2)  // net alış toplamı (KDV dahil)
  totalQuantity   Int      @default(0)

  /// Tarih
  createdAt       DateTime @default(now())
  confirmedAt     DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?

  /// Kullanıcı
  createdBy       String?

  items           PurchaseOrderItem[]

  @@index([status])
  @@index([createdAt])
}

/// Sipariş kalemi (her ürün için bir satır)
model PurchaseOrderItem {
  id              Int      @id @default(autoincrement())
  orderId         Int
  productId       Int

  /// Snapshot fiyatlar (sipariş anında dondurulur)
  listPrice       Decimal  @db.Decimal(14, 4)  // marka liste fiyatı
  isVatIncluded   Boolean  @default(false)
  netPurchasePrice Decimal @db.Decimal(14, 4)  // hesaplanmış net alış (KDV dahil, tüm iskontolar)

  /// Snapshot satış verileri
  currentStock    Int      // sipariş anındaki ana+cadde stok toplam
  dailySalesAvg   Decimal  @default(0) @db.Decimal(10, 4)  // günlük ort. satış
  daysUntilStockout Int?   // tahmini bitme süresi (gün)

  /// Sipariş miktarları
  suggestedQty    Int      // sistem önerisi
  orderedQty      Int      // gerçek sipariş miktarı (kullanıcı override edebilir)
  receivedQty     Int      @default(0)  // mal kabul edilen toplam

  /// BuyBox bilgileri (snapshot)
  buyboxPrice     Decimal? @db.Decimal(14, 4)
  ourSalePrice    Decimal? @db.Decimal(14, 4)  // mevcut satış fiyatımız (recommendedPrice veya formula)

  order           PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])

  @@unique([orderId, productId])
  @@index([orderId])
  @@index([productId])
}

enum PurchaseOrderStatus {
  DRAFT       // taslak — düzenleniyor
  CONFIRMED   // onaylandı, satıcıya gitti
  PARTIAL     // kısmen geldi
  COMPLETED   // tamamı geldi
  CANCELLED   // iptal
}

// ---------- Kampanya (Marka iskonto kampanyaları) ----------
//
// İş mantığı:
//   - Marka der: "Mart boyunca %10 iskonto"
//   - İndirim TL = PSF × (oran/100)  (PSF üzerinden TL hesaplanır)
//   - Sanal alış = mainPurchasePrice - indirim_TL
//   - Dopigo'ya yansıyan satış = formul(sanal_alış, marketplace)
//   - Tahsilat = PSF_snapshot × oran% × satılan_adet (markaya fatura kesilir)
//
// Tip:
//   BRAND     — tüm markaya uygulanır
//   PRODUCTS  — manuel barkod listesi (CampaignProduct)
//
// Çakışma:
//   - PRODUCTS, BRAND'i ezer (more specific wins)
//   - Aynı ürün eş zamanlı 2 kampanyada olamaz (form kontrol)
model Campaign {
  id                  Int            @id @default(autoincrement())
  name                String         // "Skinceuticals Mart 2026"
  type                CampaignType
  brandId             Int?           // BRAND için (zorunlu)
  discountRate        Decimal        @db.Decimal(5, 2)  // 10.00 = %10
  startDate           DateTime
  endDate             DateTime
  status              CampaignStatus @default(ACTIVE)

  // Tahsilat
  collectionDueDate   DateTime?      // marka deadline (örn. ay sonu)
  collectedAt         DateTime?
  collectionInvoiceNo String?        // bizim kestiğimiz iskonto faturası
  collectedAmount     Decimal?       @db.Decimal(12, 2)

  notes               String?
  createdAt           DateTime       @default(now())
  endedAt             DateTime?      // status ENDED'a geçtiği an
  updatedAt           DateTime       @updatedAt

  brand    Brand?            @relation(fields: [brandId], references: [id])
  products CampaignProduct[] // PRODUCTS tipi için seçilen ürünler
  sales    CampaignSale[]

  @@index([status])
  @@index([startDate, endDate])
  @@index([brandId])
}

// PRODUCTS tipi kampanyaya dahil ürünler
model CampaignProduct {
  id         Int @id @default(autoincrement())
  campaignId Int
  productId  Int

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([campaignId, productId])
  @@index([productId])
}

// Kampanya boyunca yapılan satışlar — tahsilat hesabı için snapshot
model CampaignSale {
  id                   Int       @id @default(autoincrement())
  campaignId           Int
  productId            Int
  stockMovementId      Int?      // hangi OUT'tan geldi (audit)
  quantity             Int
  psfSnapshot          Decimal   @db.Decimal(12, 2)  // satış anındaki PSF
  unitPurchaseSnapshot Decimal   @db.Decimal(12, 2)  // satış anındaki alış
  discountAmountTL     Decimal   @db.Decimal(12, 2)  // (psf × oran% × adet) tahsilat tutarı
  saleDate             DateTime  // OUT tarihi
  source               String    // "STOCK_MOVEMENT" | "DOPIGO_ORDER" (ileride)
  createdAt            DateTime  @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@index([campaignId, saleDate])
  @@index([productId])
}

enum CampaignType {
  BRAND      // tüm marka
  PRODUCTS   // seçili ürünler
}

enum CampaignStatus {
  ACTIVE     // aktif (tarih aralığında, henüz bitmedi)
  ENDED      // bitti, henüz tahsil edilmedi
  COLLECTED  // tahsilat tamam
  CANCELLED  // iptal
}

// ---------- Audit Log (kritik islemler) ----------
//
// Hangi kullanici ne zaman ne yapti — kompleks islemlerin (kullanici yonetimi,
// trendyol config, kampanya tahsilati, login fail) izi.
//
// Bu tablo silinmemeli (audit). Cron ile eski kayitlari arsivlenip silinmesi
// admin tarafindan yapilabilir.
model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     String?  // null = system
  action     String   // "USER_CREATE", "TRENDYOL_CONFIG_UPDATE", "CAMPAIGN_END", "LOGIN_FAIL", vs.
  entityType String?  // "User", "Campaign", "Product", ...
  entityId   String?
  before     Json?    // değişiklik öncesi snapshot
  after      Json?    // değişiklik sonrası
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId])
}
