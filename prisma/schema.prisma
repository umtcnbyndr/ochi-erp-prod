/// Trendyol'daki kendi satıcı kataloğumuzun snapshot'ı — son senkron sonucu.
/// `/barkod-eslestirme` audit'inde kullanılır, her sefer Trendyol'a hit etmesin diye.
model TrendyolListing {
  id           Int      @id @default(autoincrement())
  barcode      String   @unique
  productCode  String?  // Trendyol productCode (= "Model Kodu" varyantı)
  productMainId String? // Trendyol productMainId (= "Model Kodu" diğer varyantı, ds-/Skinceuticals.049 vs.)
  title        String
  brand        String?
  categoryName String?
  listPrice    Decimal? @db.Decimal(12, 2)
  salePrice    Decimal? @db.Decimal(12, 2)
  quantity     Int?
  approved     Boolean  @default(false)
  archived     Boolean  @default(false)
  rejected     Boolean  @default(false)
  onSale       Boolean  @default(false)
  rawJson      Json     // tam Trendyol response — ileride yeni alan eklenirse migration'sız
  fetchedAt    DateTime @default(now())

  // ERP Product eşleştirmesi (post-sync match ile doldurulur)
  // Excel.ModelKodu → TrendyolListing.productCode → productId tek-hop lookup için.
  productId         Int?
  productMatchedAt  DateTime?

  product Product? @relation(fields: [productId], references: [id])

  @@index([approved])
  @@index([productCode])
