// Ochi ERP — Prisma Schema
// Pharmacy ERP with marketplace-ready pricing engine

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth.js Tables ----------
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  role          UserRole  @default(STAFF)
  pharmacyId    Int       @default(1)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  @@index([pharmacyId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Core ERP Tables ----------
model Pharmacy {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Brand {
  id         Int    @id @default(autoincrement())
  pharmacyId Int    @default(1)
  name       String @unique

  // İskontolar (% — yüzde olarak tutulur, örn. 10 = %10)
  invoiceDiscount1 Decimal @default(0) @db.Decimal(5, 2)
  invoiceDiscount2 Decimal @default(0) @db.Decimal(5, 2)
  invoiceDiscount3 Decimal @default(0) @db.Decimal(5, 2)
  yearEndDiscount1 Decimal @default(0) @db.Decimal(5, 2)
  yearEndDiscount2 Decimal @default(0) @db.Decimal(5, 2)
  yearEndDiscount3 Decimal @default(0) @db.Decimal(5, 2)

  pharmacyMargin    Decimal @default(0) @db.Decimal(5, 2)
  pharmacyStockRule Int     @default(0)

  distributorInfo String?
  contactInfo     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([pharmacyId])
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subcategories Subcategory[]
  products      Product[]
}

model Subcategory {
  id         Int      @id @default(autoincrement())
  name       String
  categoryId Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([name, categoryId])
  @@index([categoryId])
}

model Marketplace {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  commissionRate Decimal  @default(0) @db.Decimal(5, 2) // %
  shippingCost   Decimal  @default(0) @db.Decimal(10, 2) // TL sabit
  withholdingTax Decimal  @default(0) @db.Decimal(5, 2) // stopaj %
  targetProfit   Decimal  @default(0) @db.Decimal(5, 2) // hedef kar %
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  prices ProductMarketplacePrice[]
}

model Product {
  id         Int @id @default(autoincrement())
  pharmacyId Int @default(1)

  name           String
  primaryBarcode String      @unique
  brandId        Int
  categoryId     Int
  subcategoryId  Int?
  vatRate        Decimal     @db.Decimal(5, 2)
  productType    ProductType @default(SINGLE)

  // Ana depo
  mainStock         Int      @default(0)
  mainPurchasePrice Decimal? @db.Decimal(12, 4) // KDV dahil, iskontolar dahil (weighted avg)

  // Cadde (eczane)
  streetStock         Int      @default(0)
  streetPurchasePrice Decimal? @db.Decimal(12, 4) // KDV hariç, fatura altı iskonto dahil
  streetPharmacyCode  String? // cadde upload'ından gelen eczane ürün kodu (ileride kullanılabilir)
  pharmacyProductCode String? @unique // EZC master kodu — alış eşleştirme için

  // Referans fiyat
  psf Decimal? @db.Decimal(12, 4)

  // Meta
  manufacturer      String?
  minStock          Int           @default(0)
  shelf             String?
  status            ProductStatus @default(ACTIVE)
  nearestExpiration DateTime?
  paoMonths         Int?

  // Takas
  exchangeStock Int @default(0)

  // Set-specific
  setSku           String?  @unique
  setExtraDiscount Decimal? @default(0) @db.Decimal(12, 4)

  // Not
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand       Brand        @relation(fields: [brandId], references: [id])
  category    Category     @relation(fields: [categoryId], references: [id])
  subcategory Subcategory? @relation(fields: [subcategoryId], references: [id])

  barcodes          ProductBarcode[]
  marketplacePrices ProductMarketplacePrice[]
  priceHistory      PriceHistory[]
  stockMovements    StockMovement[]
  exchanges         Exchange[]
  setComponents     SetComponent[]            @relation("SetProduct")
  componentOfSets   SetComponent[]            @relation("ComponentProduct")

  @@index([pharmacyId])
  @@index([brandId])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([status])
  @@index([primaryBarcode])
  @@index([productType])
}

model ProductBarcode {
  id        Int      @id @default(autoincrement())
  productId Int
  barcode   String   @unique
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([barcode])
}

model ProductMarketplacePrice {
  id               Int      @id @default(autoincrement())
  productId        Int
  marketplaceId    Int
  calculatedPrice  Decimal  @db.Decimal(12, 4)
  manualOverride   Decimal? @db.Decimal(12, 4)
  lastCalculatedAt DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  marketplace Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  @@unique([productId, marketplaceId])
  @@index([marketplaceId])
}

model SetComponent {
  id           Int @id @default(autoincrement())
  setProductId Int
  componentId  Int
  quantity     Int @default(1)

  setProduct Product @relation("SetProduct", fields: [setProductId], references: [id], onDelete: Cascade)
  component  Product @relation("ComponentProduct", fields: [componentId], references: [id])

  @@unique([setProductId, componentId])
  @@index([componentId])
}

model Counterparty {
  id        Int              @id @default(autoincrement())
  name      String
  type      CounterpartyType @default(PHARMACY)
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  exchanges      Exchange[]
  stockMovements StockMovement[]
}

model Exchange {
  id             Int               @id @default(autoincrement())
  direction      ExchangeDirection
  counterpartyId Int
  productId      Int
  quantity       Int
  price          Decimal?          @db.Decimal(12, 4)
  expirationDate DateTime?
  addedToStock   Boolean           @default(false)
  status         ExchangeStatus    @default(PENDING)
  note           String?
  createdAt      DateTime          @default(now())
  completedAt    DateTime?
  updatedAt      DateTime          @updatedAt

  counterparty Counterparty @relation(fields: [counterpartyId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])

  @@index([direction])
  @@index([status])
  @@index([counterpartyId])
  @@index([productId])
}

model EntrySession {
  id          Int         @id @default(autoincrement())
  generalNote String?
  source      EntrySource @default(PURCHASE)
  userId      String?
  createdAt   DateTime    @default(now())

  movements StockMovement[]
}

model StockMovement {
  id             Int          @id @default(autoincrement())
  productId      Int
  type           MovementType
  quantity       Int // her zaman pozitif; yön `type` ile belirlenir
  unitPrice      Decimal?     @db.Decimal(12, 4)
  counterpartyId Int?
  entrySessionId Int?
  note           String?
  expirationDate DateTime?
  source         EntrySource?
  createdAt      DateTime     @default(now())
  createdBy      String?

  product      Product       @relation(fields: [productId], references: [id])
  counterparty Counterparty? @relation(fields: [counterpartyId], references: [id])
  entrySession EntrySession? @relation(fields: [entrySessionId], references: [id])

  @@index([productId])
  @@index([type])
  @@index([createdAt])
}

model PriceHistory {
  id        Int       @id @default(autoincrement())
  productId Int
  priceType PriceType
  oldValue  Decimal?  @db.Decimal(12, 4)
  newValue  Decimal   @db.Decimal(12, 4)
  reason    String?
  changedAt DateTime  @default(now())
  changedBy String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([priceType])
  @@index([changedAt])
}

model PharmacyDataUpload {
  id              Int      @id @default(autoincrement())
  filename        String
  rowCount        Int
  newProducts     Int      @default(0)
  updatedProducts Int      @default(0)
  skippedRows     Int      @default(0)
  conflictsJson   Json?
  uploadedAt      DateTime @default(now())
  uploadedBy      String?
}

// ---------- Enums ----------
enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum ProductType {
  SINGLE
  SET
  GIFT
}

enum ProductStatus {
  ACTIVE
  PASSIVE
}

enum CounterpartyType {
  PHARMACY
  DISTRIBUTOR
  INDIVIDUAL
}

enum ExchangeDirection {
  GIVEN
  RECEIVED
}

enum ExchangeStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum EntrySource {
  PURCHASE
  RETURN
}

enum MovementType {
  IN
  OUT
  EXCHANGE_OUT
  EXCHANGE_IN
  EXCHANGE_COMPLETE
  ADJUSTMENT
  SET_CONSUMPTION
}

enum PriceType {
  MAIN_PURCHASE
  PSF
  STREET_PURCHASE
  SALE_CALCULATED
}
